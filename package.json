          "file": "images/question.pdc"
        },
        {
          "type": "raw",
          "name": "IMAGE_CALENDAR",
          "file": "images/calendar.pdc"
        },
        {
          "type": "raw",
          "name": "IMAGE_STEP",
          "file": "images/step.pdc"
